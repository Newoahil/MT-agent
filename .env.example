FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=replace_with_feishu_app_secret
FEISHU_SEND_TO=personal

FEISHU_PERSONAL_RECEIVE_ID_TYPE=open_id
FEISHU_PERSONAL_RECEIVE_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

FEISHU_GROUP_RECEIVE_ID_TYPE=chat_id
FEISHU_GROUP_RECEIVE_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

FEISHU_BOT_USE_SDK=true
FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BOT_MENTION_NAME=公域数据日报
FEISHU_BOT_PORT=8787
FEISHU_BOT_VERIFICATION_TOKEN=replace_with_feishu_verification_token
# Phase 1 HTTP callback fallback expects plaintext Feishu events. Leave Encrypt Key empty unless event decryption is implemented later.
FEISHU_BOT_ENCRYPT_KEY=

# LLM agent planner. Required for natural-language workflows such as
# "帮我铺十条 pocket3 的新链"; deterministic commands still work without it.
# Any OpenAI-compatible /chat/completions endpoint can be used.
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=
LLM_API_KEY=
# Preferred aliases for MT-agent runtime. These override LLM_* when set.
MT_AGENT_LLM_PROVIDER=
MT_AGENT_LLM_BASE_URL=
MT_AGENT_LLM_MODEL=
MT_AGENT_LLM_API_KEY=
MT_AGENT_OUTPUT_DIR=output
RENTAL_PRICE_AGENT_DIR=vendor/rental-price-agent
RENTAL_PRICE_AGENT_DAEMON_URL=
RENTAL_PRICE_AGENT_DAEMON_TOKEN=

# Legacy fallback. If personal fields are omitted, these are used as the personal target.
FEISHU_RECEIVE_ID_TYPE=open_id
FEISHU_RECEIVE_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. When set, public-traffic-report reads goods-manager /api/goods
# and writes recent 7-day submitted product IDs into the 新品池维护 sheet.
GOODS_MANAGER_BASE_URL=

# Optional. When set, closed-order-feedback:preview reads recent closed-order remarks
# from the hub API and runs local reason/confidence analysis.
CLOSED_ORDER_REMARKS_BASE_URL=
CLOSED_ORDER_REMARKS_API_TOKEN=
CLOSED_ORDER_REMARKS_SOURCE_APP_CODE=order_dispatch
